{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "akrista/bizkit",
    "type": "project",
    "description": "Batteries included starter kit for any laravel project.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "dedoc/scramble": "^0.13.28",
        "filament/filament": "^5.6.7",
        "laravel/ai": "^0.7.2",
        "laravel/fortify": "^1.37.2",
        "laravel/framework": "^13.15",
        "laravel/horizon": "^5.47.2",
        "laravel/octane": "^2.17.5",
        "laravel/pennant": "^1.23",
        "laravel/prompts": "^0.3.18",
        "laravel/pulse": "^1.7.4",
        "laravel/reverb": "^1.10.2",
        "laravel/tinker": "^3.0.2",
        "league/flysystem-aws-s3-v3": "3.0",
        "livewire/flux": "^2.14.1",
        "livewire/livewire": "^4.3.1",
        "nunomaduro/termwind": "^2.4",
        "spatie/laravel-permission": "^8.0",
        "wildside/userstamps": "^4.0"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.7",
        "driftingly/rector-laravel": "^2.5",
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.10.0",
        "laravel/boost": "^2.4.10",
        "laravel/pail": "^1.2.7",
        "laravel/pao": "^1.1.1",
        "laravel/pint": "^1.29.1",
        "laravel/sail": "^1.62",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.4",
        "pestphp/pest": "^4.7.3",
        "pestphp/pest-plugin-browser": "^4.3.1",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0.4",
        "phpunit/phpunit": "^12.5.29",
        "rector/rector": "^2.4.5",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "bun install",
            "bun run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "bunx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve --host=localhost\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"bun run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "update:requirements": [
            "composer bump",
            "bunx npm-check-updates -u"
        ],
        "build": [
            "Composer\\Config::disableProcessTimeout",
            "@php artisan optimize:clear",
            "@php artisan livewire:publish --assets",
            "@php artisan filament:upgrade",
            "@php artisan storage:link",
            "bun run build",
            "@php artisan optimize"
        ],
        "ide": [
            "Composer\\Config::disableProcessTimeout",
            "@php artisan ide-helper:generate",
            "@php artisan ide-helper:models -NR",
            "@php artisan ide-helper:meta"
        ],
        "lint": [
            "rector",
            "pint --parallel",
            "pint --parallel --config=pint.filament.json app/Filament"
        ],
        "lint:check": [
            "pint --parallel --test",
            "pint --parallel --test --config=pint.filament.json app/Filament"
        ],
        "ci:check": [
            "Composer\\Config::disableProcessTimeout",
            "@test"
        ],
        "test:type-coverage": "pest --type-coverage --min=100",
        "test:lint": [
            "pint --parallel --test",
            "pint --parallel --test --config=pint.filament.json app/Filament",
            "rector --dry-run"
        ],
        "test:unit": "XDEBUG_MODE=\"coverage\" pest --parallel --coverage --exactly=100.0",
        "test:types": "phpstan --memory-limit=256M",
        "test": [
            "@php artisan config:clear --ansi",
            "@test:lint",
            "@test:types",
            "@test:type-coverage",
            "@test:unit"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [],
            "installer": {
                "post-create-project": []
            }
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
